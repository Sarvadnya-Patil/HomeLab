# Enable label-based updates (Highly Recommended: true)
# Only updates containers labeled com.centurylinklabs.watchtower.enable=true
WATCHTOWER_LABEL_ENABLE=true

# Automatically remove old, unused images after update (true/false)
WATCHTOWER_CLEANUP=true

# 6-Field Cron schedule for updates (default: 4:00 AM every day)
# Format: second minute hour day-of-month month day-of-week
WATCHTOWER_SCHEDULE=0 0 4 * * *

# Timezone for the scheduling daemon
TZ=UTC
