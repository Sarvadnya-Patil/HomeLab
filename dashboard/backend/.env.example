# HomeLab OS Backend Configuration Variables

# 1. Execution Settings
PORT=8081
NODE_ENV=development
LOG_LEVEL=info

# 2. Security Configuration
# CRITICAL: This secret key is required when running in production mode.
# Generate a secure random string (e.g., using openssl rand -hex 32)
JWT_SECRET=your-32-character-random-jwt-secret-key-here

# 3. Infrastructure Integrations
# Docker Socket Proxy TCP bridge endpoint URL
DOCKER_PROXY_URL=http://docker-proxy:2375
